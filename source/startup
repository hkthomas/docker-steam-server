#!/bin/bash
# Startup script for steam dedicated server.
# REMEMBER TO DROP Privileges for steam (su steam -c '').

CUSTOM=/data/custom_server

set -u -e
echo '--------------------------------------'
echo 'Propagating steam user permissions ...'
PUID=${PUID:-911}
PGID=${PGID:-911}
groupmod -o -g ${PGID} steam
usermod -o -u ${PUID} steam
mkdir -p ${SERVER_DIR}
chown steam:steam -R /data ${SERVER_DIR}
chmod 0700 /data/custom_server
echo "PUID=$(id -u steam)"
echo "PGID=$(id -g steam)"

if [ ${UPDATE_OS} -eq 1 ]; then
  echo '--------------------------------------'
  echo 'Updating image OS ...'
  apt-get --quiet update && apt-get --quiet --yes upgrade
fi

# Determine login credentials (use account if provided, otherwise anonymous)
if [ -n "${STEAM_USERNAME:-}" ] && [ -n "${STEAM_PASSWORD:-}" ]; then
  STEAM_LOGIN="${STEAM_USERNAME} ${STEAM_PASSWORD}"
  echo 'Using Steam account authentication ...'
else
  STEAM_LOGIN="anonymous"
  echo 'Using anonymous Steam authentication ...'
fi

if [ ${UPDATE_STEAM} -eq 1 ]; then
  echo '--------------------------------------'
  echo "Updating steamcmd for ${PLATFORM} ..."
  su steam -c "steamcmd \
    +@sSteamCmdForcePlatformType ${PLATFORM} \
    +login ${STEAM_LOGIN} \
    +quit"
fi

if [ ${UPDATE_SERVER} -eq 1 ]; then
  echo '--------------------------------------'
  echo "Updating app ${STEAM_APP_ID} ..."

  # Build beta arguments if specified
  BETA_ARGS=""
  if [ -n "${STEAM_BETA:-}" ]; then
    BETA_ARGS="-beta ${STEAM_BETA}"
    if [ -n "${STEAM_BETA_PASSWORD:-}" ]; then
      BETA_ARGS="${BETA_ARGS} -betapassword ${STEAM_BETA_PASSWORD}"
    fi
  fi

  su steam -c "steamcmd \
    +@sSteamCmdForcePlatformType ${PLATFORM} \
    +force_install_dir ${SERVER_DIR} \
    +login ${STEAM_LOGIN} \
    +app_update ${STEAM_APP_ID} ${BETA_ARGS} \
    ${STEAM_APP_EXTRAS} \
    +quit"
fi

echo '--------------------------------------'
echo "Handing startup over to ${CUSTOM} ..."
exec ${CUSTOM}
